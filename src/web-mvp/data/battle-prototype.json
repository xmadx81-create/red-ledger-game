  "description": "전투 프로토타입 셋업. card-stat-schema.json의 1차 스탯→파생 전투 스탯 공식을 실제로 돌려보기 위한 데이터. 파티/적의 1차 스탯은 등급 budget을 직업 성향대로 분배한 v0 값. 행동 효과는 combat-actions.json을 전투용으로 매핑.",
  "blood": { "start": 4, "perTurn": 3, "max": 12 },
  "derivedFormulas": {
    "note": "card-stat-schema.json derivedCombatStats와 동일. JS에서 동일하게 구현.",
    "HP": "VIT*8 + STR*2",
    "PATK": "STR*2 + DEX*0.5",
    "MATK": "INT*2 + ACC*0.5",
    "DEF": "VIT*1.5 + STR*0.5",
    "SPD": "DEX*2",
    "HIT": "ACC*1.5 + DEX*0.5",
    "EVA": "DEX*1.2",
    "CRIT": "ACC*0.7 + LUK*0.8",
    "PERSUADE": "CHA*1.5 + INT*0.5",
    "RESIST": "WIL*1.5 + VIT*0.5"
  },
